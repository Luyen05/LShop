<!-- Hero Banner -->
<div class="container-fluid hero-tech mb-5">
    <div class="d-flex flex-column align-items-center justify-content-center text-center" style="min-height: 360px;">
        <p class="hero-badge mb-3">TECH STORE VIETNAM</p>
        <h1 class="display-4 text-white font-weight-semi-bold mb-3">Sản Phẩm Công Nghệ Chính Hãng</h1>
        <p class="text-white mb-4">Laptop, điện thoại, gaming gear và phụ kiện cao cấp cho học tập, làm việc và giải trí</p>
        <div class="d-flex flex-wrap justify-content-center">
            <a href="/shop" class="btn btn-light font-weight-semi-bold px-4 py-2 m-2">Mua Sắm Ngay</a>
            <a href="/contact" class="btn btn-outline-light font-weight-semi-bold px-4 py-2 m-2">Tư Vấn Cấu Hình</a>
        </div>
    </div>
</div>

<!-- Featured Products Section -->
<div class="container-fluid pt-3">
    <div class="text-center mb-4">
        <h2 class="section-title px-5"><span class="px-2">Sản Phẩm Nổi Bật</span></h2>
    </div>
    <div class="row px-xl-5 pb-3">
        {{#each products}}
            {{> product-item this}}
        {{/each}}
    </div>
</div>

<!-- Categories Section -->
<div class="container-fluid my-4">
    <div class="text-center mb-4">
        <h2 class="section-title px-5"><span class="px-2">Danh Mục Sản Phẩm</span></h2>
    </div>
    <div class="row px-xl-5 pb-3">
        <div class="col-lg-3 col-md-6 pb-3">
            <a class="text-decoration-none" href="/shop?cat=laptop">
                <div class="cat-item d-flex flex-column border rounded p-4 bg-light">
                    <p class="text-center mb-2"><i class="fa fa-laptop fa-2x text-primary"></i></p>
                    <h5 class="font-weight-bold mb-0 text-center">Laptop & PC</h5>
                </div>
            </a>
        </div>
        <div class="col-lg-3 col-md-6 pb-3">
            <a class="text-decoration-none" href="/shop?cat=phone">
                <div class="cat-item d-flex flex-column border rounded p-4 bg-light">
                    <p class="text-center mb-2"><i class="fa fa-mobile-alt fa-2x text-success"></i></p>
                    <h5 class="font-weight-bold mb-0 text-center">Điện Thoại</h5>
                </div>
            </a>
        </div>
        <div class="col-lg-3 col-md-6 pb-3">
            <a class="text-decoration-none" href="/shop?cat=accessories">
                <div class="cat-item d-flex flex-column border rounded p-4 bg-light">
                    <p class="text-center mb-2"><i class="fa fa-headphones fa-2x text-warning"></i></p>
                    <h5 class="font-weight-bold mb-0 text-center">Phụ Kiện</h5>
                </div>
            </a>
        </div>
        <div class="col-lg-3 col-md-6 pb-3">
            <a class="text-decoration-none" href="/shop?cat=gaming">
                <div class="cat-item d-flex flex-column border rounded p-4 bg-light">
                    <p class="text-center mb-2"><i class="fa fa-gamepad fa-2x text-danger"></i></p>
                    <h5 class="font-weight-bold mb-0 text-center">Gaming Gear</h5>
                </div>
            </a>
        </div>
    </div>
</div>