<!-- Page Header Start -->
<div class="container-fluid bg-secondary mb-5">
    <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 300px">
        <h1 class="font-weight-semi-bold text-uppercase mb-3">Đăng Nhập</h1>
        <div class="d-inline-flex">
            <p class="m-0"><a href="/">Trang Chủ</a></p>
            <p class="m-0 px-2">-</p>
            <p class="m-0">Đăng Nhập</p>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Login Start -->
<div class="container-fluid pt-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="bg-light p-30 rounded">
                <form method="post">
                    <div class="form-group">
                        <label>Email</label>
                        <input class="form-control" type="email" placeholder="Nhập email" required>
                    </div>
                    <div class="form-group">
                        <label>Mật Khẩu</label>
                        <input class="form-control" type="password" placeholder="Nhập mật khẩu" required>
                    </div>
                    <div class="custom-control custom-checkbox mb-3">
                        <input type="checkbox" class="custom-control-input" id="customCheck1">
                        <label class="custom-control-label" for="customCheck1">Nhớ tôi</label>
                    </div>
                    <button class="btn btn-primary btn-block py-3 mb-4" type="submit">Đăng Nhập</button>
                </form>
                <p class="text-center mb-0">Bạn chưa có tài khoản? <a href="">Đăng ký tại đây</a></p>
            </div>
        </div>
    </div>
</div>
<!-- Login End -->
