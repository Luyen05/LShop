<div class="col-lg-4 col-md-6 col-sm-12 pb-4">
    <div class="product-card h-100">
        <a href="/product/{{id}}" class="product-media">
            {{#if image}}
                <img src="{{image}}" alt="{{name}}" class="img-fluid" style="max-width: 100%; max-height: 100%;">
            {{else}}
                <i class="fa fa-{{icon}} fa-3x text-muted"></i>
            {{/if}}
            <span class="product-chip">{{category}}</span>
        </a>

        <div class="product-body">
            <h6 class="product-title mb-2">
                <a href="/product/{{id}}" class="text-dark text-decoration-none">{{name}}</a>
            </h6>

            {{#if rating}}
                <small class="d-block mb-2 text-muted">
                    {{#repeat rating}}<i class="fas fa-star text-warning"></i>{{/repeat}}
                    ({{reviews}} đánh giá)
                </small>
            {{/if}}

            <div class="d-flex align-items-center mb-3">
                <h6 class="text-primary font-weight-bold mb-0 mr-2">{{formatPrice price}}</h6>
                {{#if oldPrice}}
                    <small class="text-muted"><s>{{formatPrice oldPrice}}</s></small>
                {{/if}}
            </div>

            <div class="d-flex justify-content-between align-items-center">
                <a href="/product/{{id}}" class="btn btn-sm btn-primary py-2 px-3">Xem Chi Tiết</a>
                <button class="btn btn-sm btn-outline-primary py-2 px-3 add-to-cart" data-product-id="{{id}}">
                    <i class="fa fa-shopping-cart"></i>
                </button>
            </div>
        </div>
    </div>
</div>
